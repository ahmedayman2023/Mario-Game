{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and state",
      "type": "object",
      "properties": {
        "current_study_topic": {
          "type": "string",
          "description": "The current topic the user is studying"
        },
        "cooldownEndTime": {
          "type": "number",
          "description": "Timestamp when the nutrition cooldown ends"
        }
      }
    },
    "NutritionItem": {
      "title": "NutritionItem",
      "description": "A nutrition task for the user",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The text of the nutrition item"
        },
        "completed": {
          "type": "boolean",
          "description": "Whether the item is completed"
        },
        "iconType": {
          "type": "string",
          "description": "The type of icon to display",
          "enum": ["drink", "food", "energy"]
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this item"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp when the item was created"
        }
      },
      "required": ["text", "completed", "iconType", "userId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles"
    },
    "nutritionItems/{itemId}": {
      "schema": {
        "$ref": "#/entities/NutritionItem"
      },
      "description": "Nutrition items for users"
    }
  }
}
