{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and state",
      "type": "object",
      "properties": {
        "current_study_topic": {
          "type": "string",
          "description": "The current topic the user is studying"
        },
        "cooldownEndTime": {
          "type": "number",
          "description": "Timestamp when the nutrition cooldown ends"
        }
      }
    },
    "NutritionItem": {
      "title": "NutritionItem",
      "description": "A nutrition product item for the user",
      "type": "object",
      "properties": {
        "product": {
          "type": "string",
          "description": "The name of the product"
        },
        "cost": {
          "type": "number",
          "description": "The cost of the product"
        },
        "quantity": {
          "type": "string",
          "description": "The quantity per week"
        },
        "unit": {
          "type": "string",
          "description": "The unit of measurement (e.g., ml, piece, gram)"
        },
        "time": {
          "type": "string",
          "description": "The time to eat the product"
        },
        "sugarLevel": {
          "type": "string",
          "description": "The blood sugar level or curve"
        },
        "complexCarbs": {
          "type": "string",
          "description": "Complex carbohydrates per 100 units"
        },
        "fiber": {
          "type": "string",
          "description": "Fiber per 100 units"
        },
        "protein": {
          "type": "string",
          "description": "Protein per 100 units"
        },
        "goal": {
          "type": "string",
          "description": "The goal or purpose of the item"
        },
        "dayOfWeek": {
          "type": "string",
          "description": "The day of the week this item belongs to"
        },
        "category": {
          "type": "string",
          "description": "The category of the item (protein, fiber, complexCarbs, sugarLevel, general)"
        },
        "isCompleted": {
          "type": "boolean",
          "description": "Whether the nutrition item has been consumed/completed"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this item"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp when the item was created"
        }
      },
      "required": ["product", "cost", "quantity", "userId", "createdAt"]
    },
    "Meal": {
      "title": "Meal",
      "description": "A combination of multiple nutrition items",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the meal"
        },
        "itemIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of nutrition item IDs included in this meal"
        },
        "dayOfWeek": {
          "type": "string",
          "description": "The day of the week this meal belongs to"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this meal"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp when the meal was created"
        }
      },
      "required": ["name", "itemIds", "dayOfWeek", "userId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles"
    },
    "nutritionItems/{itemId}": {
      "schema": {
        "$ref": "#/entities/NutritionItem"
      },
      "description": "Nutrition items for users"
    },
    "meals/{mealId}": {
      "schema": {
        "$ref": "#/entities/Meal"
      },
      "description": "Meals combining multiple nutrition items"
    }
  }
}
