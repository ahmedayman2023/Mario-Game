rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function isValidOptionalNumberOrNull(field) {
      return !(field in request.resource.data) || request.resource.data[field] is number || request.resource.data[field] == null;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return isValidOptionalString('current_study_topic', 0, 200) &&
             isValidOptionalNumberOrNull('cooldownEndTime');
    }

    function isValidNutritionItem() {
      return hasRequiredFields(['product', 'cost', 'quantity', 'userId', 'createdAt']) &&
             validStringLength('product', 1, 200) &&
             request.resource.data.cost is number &&
             validStringLength('quantity', 1, 100) &&
             (!( 'unit' in request.resource.data ) || validStringLength('unit', 0, 50)) &&
             (!( 'time' in request.resource.data ) || validStringLength('time', 0, 50)) &&
             (!( 'sugarLevel' in request.resource.data ) || validStringLength('sugarLevel', 0, 100)) &&
             (!( 'complexCarbs' in request.resource.data ) || validStringLength('complexCarbs', 0, 100)) &&
             (!( 'fiber' in request.resource.data ) || validStringLength('fiber', 0, 100)) &&
             (!( 'protein' in request.resource.data ) || validStringLength('protein', 0, 100)) &&
             (!( 'goal' in request.resource.data ) || validStringLength('goal', 0, 100)) &&
             (!( 'dayOfWeek' in request.resource.data ) || validStringLength('dayOfWeek', 0, 50)) &&
             (!( 'category' in request.resource.data ) || validStringLength('category', 0, 50)) &&
             (!( 'isCompleted' in request.resource.data ) || request.resource.data.isCompleted is bool) &&
             request.resource.data.userId == request.auth.uid &&
             request.resource.data.createdAt is number;
    }

    function isValidMeal() {
      return hasRequiredFields(['name', 'itemIds', 'dayOfWeek', 'userId', 'createdAt']) &&
             validStringLength('name', 1, 200) &&
             request.resource.data.itemIds is list &&
             request.resource.data.itemIds.size() <= 50 &&
             validStringLength('dayOfWeek', 1, 50) &&
             request.resource.data.userId == request.auth.uid &&
             request.resource.data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser();
      allow delete: if isOwner(userId);
    }

    match /nutritionItems/{itemId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidNutritionItem() && uidUnchanged();
      allow update: if isDocOwner() && isValidNutritionItem() && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /meals/{mealId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidMeal() && uidUnchanged();
      allow update: if isDocOwner() && isValidMeal() && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
